# ===== Database =====
DATABASE_URL=postgresql://autotrading:autotrading_dev@localhost:5432/autotrading
REDIS_URL=redis://localhost:6379

# ===== Auth =====
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
ENCRYPTION_KEY=your-32-byte-hex-key-here

# ===== KIS (한국투자증권 — 국내주식 + 해외주식) =====
KIS_APP_KEY=your-kis-app-key
KIS_APP_SECRET=your-kis-app-secret
KIS_ACCOUNT_NO=your-account-number
KIS_ENV=demo  # demo or real

# ===== Alpaca (미국주식 전용) =====
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_API_SECRET=your-alpaca-api-secret
ALPACA_ENV=demo  # demo (paper) or real

# ===== Kiwoom (키움증권 — Windows 프록시) =====
KIWOOM_PROXY_URL=http://localhost:5000

# ===== Binance (암호화폐) =====
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret
BINANCE_ENV=demo  # demo (testnet) or real

# ===== Upbit (암호화폐) =====
UPBIT_ACCESS_KEY=your-upbit-access-key
UPBIT_SECRET_KEY=your-upbit-secret-key

# ===== Toss Payments =====
TOSS_CLIENT_KEY=your-toss-client-key
TOSS_SECRET_KEY=your-toss-secret-key

# ===== Analytics =====
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-token

# ===== Email =====
RESEND_API_KEY=your-resend-api-key

# ===== Notifications =====
WEBHOOK_URL=https://hooks.slack.com/services/xxx

# ===== Trading Daemon =====
TRADING_MODE=paper  # paper or live
TRADING_SYMBOLS=005930,AAPL,BTCUSDT
TRADING_STRATEGY=ma_crossover
POLL_INTERVAL=60000
