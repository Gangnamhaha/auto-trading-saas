{
  "name": "@autotrading/trading-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "daemon": "bun run src/cli.ts",
    "daemon:paper": "TRADING_MODE=paper bun run src/cli.ts",
    "daemon:live": "TRADING_MODE=live bun run src/cli.ts"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "eslint": "^8.55.0",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4"
  },
  "dependencies": {
    "node-fetch": "^3.3.2"
  }
}
